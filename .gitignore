# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Next.js build output ──────────────────────────────────────────────────────
.next/
out/
dist/

# ── Database (runtime data, not committed) ────────────────────────────────────
data/*.sqlite
data/*.sqlite-shm
data/*.sqlite-wal

# ── Uploaded CV files (user data, not code) ───────────────────────────────────
data/cvs/

# ── RenderCV compiled output (regenerated on demand) ─────────────────────────
data/rendercv_output/

# CV version YAMLs (generated/edited at runtime, not source code)
data/cv_versions/

# ── Legacy CV YAML ────────────────────────────────────────────────────────────
data/cv.yaml

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── OS & editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── TypeScript cache ──────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Package manager lock (keep whichever you use, delete the others) ──────────
# If using npm, keep package-lock.json and ignore the rest:
yarn.lock
pnpm-lock.yaml
bun.lockb
coverage/
playwright-report/
test-results/